{
  "manifest_version": 3,
  "name": "Basic Color Picker",
  "version": "0.1.0",
  "description": "Click the icon to drop multiple color pins on any page. Copy HEX, RGB, HSL, Oklab, Oklch, or Tailwind class. Persistent history.",
  "action": {
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "32": "src/icons/icon-32.png",
      "48": "src/icons/icon-48.png",
      "128": "src/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage", "notifications"],
  "icons": {
    "16": "src/icons/icon-16.png",
    "32": "src/icons/icon-32.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  }
}
